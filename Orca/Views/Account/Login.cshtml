@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="section" style="max-width:420px;margin:0 auto;">
    <div class="auth-card">
        <h1 class="detail-title" style="margin-bottom:0.5rem;">Giriş Yap</h1>
        <p style="color:#7777aa;font-size:13px;margin-bottom:1.5rem;">Hesabına giriş yap</p>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error">@ViewBag.Error</div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <input type="text" name="username" class="form-input" placeholder="Kullanıcı adın" required />
            </div>
            <div class="form-group">
                <label>Şifre</label>
                <input type="password" name="password" class="form-input" placeholder="Şifren" required />
            </div>
            <button type="submit" class="btn-primary" style="width:100%;margin-top:0.5rem;">Giriş Yap</button>
        </form>

        <p style="text-align:center;margin-top:1rem;font-size:13px;color:#7777aa;">
            Hesabın yok mu?
            <a asp-controller="Account" asp-action="Register" style="color:#00f5ff;">Kayıt Ol</a>
        </p>
    </div>
</div>