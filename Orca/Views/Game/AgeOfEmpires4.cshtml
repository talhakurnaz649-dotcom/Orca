@{
    ViewData["Title"] = "Age of Empires 4";
}

<div class="section">
    <div class="detail-card">
        <div class="detail-images">
            <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/1466860/header.jpg" alt="Age of Empires 4" class="detail-main-img" style="width:100%;border-radius:8px;margin-bottom:10px;object-fit:cover;" />
            <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/1466860/ss_4a9a0c4f9b6d2d8b08a7f8e5e434090867f72e7c.1920x1080.jpg" alt="Age of Empires 4 2" class="detail-main-img" style="width:100%;border-radius:8px;object-fit:cover;" />
        </div>
        <div class="detail-info">
            <div class="detail-category">Strateji</div>
            <h1 class="detail-title">Age of Empires 4</h1>
            <p class="detail-desc">
                Age of Empires 4, efsanevi strateji serisinin en yeni ve en görkemli oyunudur.
                Tarihin en büyük medeniyetlerini yönetin, ordular kurun ve rakiplerinizi yenilgiye uğratın.
                8 farklı medeniyet, zengin kampanya modu ve rekabetçi çok oyunculu modlarıyla saatlerce eğlence sunar.
            </p>
            <div class="detail-meta">
                <span class="badge-platform">PC</span>
                <span class="game-rating">⭐ 4.3 / 5</span>
            </div>
            <div class="detail-price-row">
                <span class="game-price big">₺449</span>
            </div>
            <a class="btn-primary" href="#">
                <i class="ti ti-shopping-cart-plus"></i> Sepete Ekle
            </a>
            <a class="btn-secondary" href="/">← Geri Dön</a>
        </div>
    </div>
</div>
