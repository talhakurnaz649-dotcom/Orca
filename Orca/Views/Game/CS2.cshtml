@{
    ViewData["Title"] = "CS2";
}

<div class="section">
    <div class="detail-card">
        <div class="detail-images">
            <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/730/header.jpg" alt="CS2" class="detail-main-img" style="width:100%;border-radius:8px;margin-bottom:10px;object-fit:cover;" />
            <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/730/ss_34090867f72e7c4570b2f9b6d2d8b08a7f8e5e4.1920x1080.jpg" alt="CS2 2" class="detail-main-img" style="width:100%;border-radius:8px;object-fit:cover;" />
        </div>
        <div class="detail-info">
            <div class="detail-category">Savaş</div>
            <h1 class="detail-title">Counter-Strike 2</h1>
            <p class="detail-desc">
                Counter-Strike 2, dünyanın en popüler çevrimiçi aksiyon oyununun en gelişmiş versiyonudur.
                Taktiksel takım bazlı oynanışı, gerçekçi silah mekaniği ve rekabetçi modlarıyla milyonlarca oyuncuyu bir araya getirir.
                Source 2 motoruyla tamamen yenilenmiş grafikler ve fizik sistemi sunar.
            </p>
            <div class="detail-meta">
                <span class="badge-platform">PC</span>
                <span class="game-rating">⭐ 4.5 / 5</span>
            </div>
            <div class="detail-price-row">
                <span class="game-price big">Ücretsiz</span>
            </div>
            <a class="btn-primary" href="#">
                <i class="ti ti-shopping-cart-plus"></i> Sepete Ekle
            </a>
            <a class="btn-secondary" href="/">← Geri Dön</a>
        </div>
    </div>
</div>