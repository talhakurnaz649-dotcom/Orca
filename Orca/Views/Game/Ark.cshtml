@{
    ViewData["Title"] = "ARK Survival Ascended";
}

<div class="section">
    <div class="detail-card">
        <div class="detail-images">
            <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/2399830/header.jpg" alt="ARK" class="detail-main-img" style="width:100%;border-radius:8px;margin-bottom:10px;object-fit:cover;" />
            <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/2399830/ss_6a9a0c4f9b6d2d8b08a7f8e5e434090867f72e7c.1920x1080.jpg" alt="ARK 2" class="detail-main-img" style="width:100%;border-radius:8px;object-fit:cover;" />
        </div>
        <div class="detail-info">
            <div class="detail-category">Hayatta Kalma</div>
            <h1 class="detail-title">ARK Survival Ascended</h1>
            <p class="detail-desc">
                ARK Survival Ascended, Unreal Engine 5 ile yeniden yapılandırılmış efsanevi hayatta kalma oyununun modern versiyonudur.
                Dev dinozorları evcilleştirin, üsler inşa edin ve gizemli adalarda hayatta kalmak için mücadele edin.
                Arkadaşlarınızla birlikte ya da tek başınıza bu vahşi dünyada ayakta kalmaya çalışın.
            </p>
            <div class="detail-meta">
                <span class="badge-platform">PC</span>
                <span class="game-rating">⭐ 4.0 / 5</span>
            </div>
            <div class="detail-price-row">
                <span class="game-price big">₺599</span>
            </div>
            <a class="btn-primary" href="#">
                <i class="ti ti-shopping-cart-plus"></i> Sepete Ekle
            </a>
            <a class="btn-secondary" href="/">← Geri Dön</a>
        </div>
    </div>
</div>