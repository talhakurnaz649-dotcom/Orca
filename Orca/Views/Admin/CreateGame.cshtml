@{
    ViewData["Title"] = "Yeni Oyun Ekle";
    var categories = ViewBag.Categories as List<Orca.Models.Category>;
}

<div class="section" style="max-width:600px;margin:0 auto;">
    <div class="section-header">
        <div class="section-title">Yeni Oyun Ekle</div>
    </div>

    <div class="auth-card">
        <form asp-controller="Admin" asp-action="CreateGame" method="post">
            <div class="form-group">
                <label>Oyun Adı</label>
                <input type="text" name="title" class="form-input" required />
            </div>
            <div class="form-group">
                <label>Açıklama</label>
                <textarea name="description" class="form-input" rows="4" style="resize:vertical;"></textarea>
            </div>
            <div class="form-group">
                <label>Fiyat</label>
                <input type="number" name="price" class="form-input" step="0.01" required />
            </div>
            <div class="form-group">
                <label>Eski Fiyat (opsiyonel)</label>
                <input type="number" name="oldPrice" class="form-input" step="0.01" />
            </div>
            <div class="form-group">
                <label>Resim URL</label>
                <input type="text" name="imageUrl" class="form-input" />
            </div>
            <div class="form-group">
                <label>Kategori</label>
                <select name="categoryId" class="form-input">
                    @if (categories != null)
                    {
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryId">@cat.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Platform</label>
                <input type="text" name="platform" class="form-input" placeholder="PC, PS5, Xbox..." required />
            </div>
            <div class="form-group">
                <label>Puan (0-5)</label>
                <input type="number" name="rating" class="form-input" step="0.1" min="0" max="5" value="0" required />
            </div>
            <div class="form-group">
                <label>Stok</label>
                <input type="number" name="stock" class="form-input" value="100" required />
            </div>
            <div class="form-group" style="display:flex;gap:1rem;">
                <label style="display:flex;align-items:center;gap:6px;">
                    <input type="checkbox" name="isActive" value="true" checked /> Aktif
                </label>
                <label style="display:flex;align-items:center;gap:6px;">
                    <input type="checkbox" name="isFeatured" value="true" /> Öne Çıkan
                </label>
            </div>
            <button type="submit" class="btn-primary" style="width:100%;margin-top:0.5rem;">Oyun Ekle</button>
            <a class="btn-secondary" asp-controller="Admin" asp-action="Games" style="display:block;text-align:center;margin-top:0.5rem;">Geri Dön</a>
        </form>
    </div>
</div>